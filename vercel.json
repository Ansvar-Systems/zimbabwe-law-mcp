{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "rewrites": [
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/health", "destination": "/api/health" }
  ],
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "{data/database.db,node_modules/@ansvar/mcp-sqlite/dist/**}"
    },
    "api/health.ts": {
      "maxDuration": 10,
      "memory": 512,
      "includeFiles": "{data/database.db,node_modules/@ansvar/mcp-sqlite/dist/**}"
    }
  },
  "crons": [
    {
      "path": "/api/health",
      "schedule": "*/5 * * * *"
    }
  ]
}
